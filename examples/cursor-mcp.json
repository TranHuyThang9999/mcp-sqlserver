{
  "mcpServers": {
    "sqlserver": {
      "command": "<path-to-mcp-sqlserver.exe>",
      "env": {
        "SQL_SERVER_HOST": "localhost",
        "SQL_SERVER_PORT": "1433",
        "SQL_SERVER_USER": "sa",
        "SQL_SERVER_PASSWORD": "your_password",
        "SQL_SERVER_DATABASE": "your_database",
        "MCP_SQLSERVER_MAX_ROWS": "500"
      }
    }
  }
}
